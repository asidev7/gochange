# Service systemd — GoChange (Gunicorn)
# Copier vers : /etc/systemd/system/gochange.service
# Adapter User/Group et les chemins si besoin.

[Unit]
Description=GoChange Gunicorn daemon
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/gochange
# Socket Unix dans /run/gochange (créé par systemd), évite tout conflit de port
RuntimeDirectory=gochange
# settings.py charge le .env via python-dotenv (pas besoin d'EnvironmentFile)
ExecStart=/var/www/gochange/venv/bin/gunicorn \
    --workers 3 \
    --bind unix:/run/gochange/gochange.sock \
    --access-logfile - \
    --error-logfile - \
    config.wsgi:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
