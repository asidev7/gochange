# --------------------------------------------------------------------------- #
# GoChange — .env de PRODUCTION (à copier en /var/www/gochange/.env sur le VPS)
#   - Ne jamais committer ce fichier rempli.
#   - Générer une SECRET_KEY :  python -c "import secrets;print(secrets.token_urlsafe(60))"
# --------------------------------------------------------------------------- #

SECRET_KEY=REMPLACEZ_PAR_UNE_CLE_ALEATOIRE
DEBUG=False
ALLOWED_HOSTS=gochange.store,www.gochange.store
CSRF_TRUSTED_ORIGINS=https://gochange.store,https://www.gochange.store
SITE_URL=https://gochange.store

# --- Base de données PostgreSQL (recommandé en prod) ------------------------
DATABASE_URL=postgres://gochange:MOT_DE_PASSE_DB@localhost:5432/gochange

# --- E-mail (SMTP réel) -----------------------------------------------------
EMAIL_HOST=smtp.votre-fournisseur.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@gochange.store
EMAIL_HOST_PASSWORD=MOT_DE_PASSE_SMTP
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=GoChange <no-reply@gochange.store>
CONTACT_EMAIL=contact@gochange.store
WHATSAPP_NUMBER=+229XXXXXXXX

# --- Paiements (clés LIVE pour encaisser réellement) ------------------------
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=live

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Compte admin créé par `manage.py seed`
ADMIN_EMAIL=admin@gochange.store
ADMIN_PASSWORD=METTEZ_UN_MOT_DE_PASSE_FORT
