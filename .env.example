# --------------------------------------------------------------------------- #
# GoChange — exemple de configuration. Copier en .env et compléter.
#   cp .env.example .env
# --------------------------------------------------------------------------- #

# --- Django -----------------------------------------------------------------
SECRET_KEY=changez-moi-en-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.gochange.store
CSRF_TRUSTED_ORIGINS=https://gochange.store,https://www.gochange.store
SITE_URL=https://gochange.store

# --- Base de données --------------------------------------------------------
# Laisser vide pour SQLite (dev). Pour PostgreSQL :
# DATABASE_URL=postgres://gochange:motdepasse@localhost:5432/gochange
DATABASE_URL=

# --- E-mail (laisser vide => affichage console en dev) ----------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=GoChange <no-reply@gochange.store>
CONTACT_EMAIL=contact@gochange.store
WHATSAPP_NUMBER=+22990000000

# --- PayDunya (paiements XOF) -----------------------------------------------
# Clés test : https://app.paydunya.com (sandbox)  →  PAYDUNYA_MODE=test
# Clés live  : tableau de bord PayDunya            →  PAYDUNYA_MODE=live
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=live

# --- Paystack (paiements NGN) -----------------------------------------------
# Clés test : sk_test_... / pk_test_...   (https://dashboard.paystack.com)
# Clés live : sk_live_... / pk_live_...
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# IMPORTANT
# - Dès que PAYDUNYA_MASTER_KEY ET PAYSTACK_SECRET_KEY sont renseignées,
#   les vrais appels API sont utilisés (plus de simulation).
# - Mettez vos clés LIVE ici + PAYDUNYA_MODE=live pour encaisser réellement.
# - Si une de ces clés est vide → MODE SIMULATION (aucun appel réseau réel),
#   pratique pour tester les flux sans clé.
